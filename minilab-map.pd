#N canvas 50 50 880 470 12;
#X text 20 10 MiniLab 3 -> folk-drone map. Robust to programs A and B (listens to both CC sets).;
#X text 20 430 Faders=voice mix. K1=filter K2=warmth K3=reverb K8=volume. True chip lock needs Arturia MCC on desktop.;
#X obj 20 60 ctlin 14;
#X obj 20 90 ctlin 82;
#X obj 20 120 / 127;
#X obj 20 150 s fader1;
#X obj 130 60 ctlin 15;
#X obj 130 90 ctlin 83;
#X obj 130 120 / 127;
#X obj 130 150 s fader2;
#X obj 240 60 ctlin 30;
#X obj 240 90 ctlin 85;
#X obj 240 120 / 127;
#X obj 240 150 s fader3;
#X obj 350 60 ctlin 31;
#X obj 350 90 ctlin 17;
#X obj 350 120 / 127;
#X obj 350 150 s fader4;
#X obj 470 60 ctlin 117;
#X obj 470 90 ctlin 16;
#X obj 470 120 / 127;
#X obj 470 150 s vol;
#X obj 580 60 ctlin 89;
#X obj 580 90 ctlin 76;
#X obj 580 120 / 127;
#X obj 580 150 s wet;
#X obj 690 60 ctlin 86;
#X obj 690 90 * 120;
#X obj 690 120 + 200;
#X obj 690 150 s mcut;
#X obj 790 60 ctlin 87;
#X obj 790 90 * 40;
#X obj 790 120 + 80;
#X obj 790 150 s cutoff;
#X text 20 190 A;
#X text 130 190 B;
#X text 240 190 C;
#X text 350 190 N;
#X text 470 190 VOL;
#X text 580 190 WET;
#X text 690 190 FILTER;
#X text 790 190 WARMTH;
#X obj 20 260 loadbang;
#X obj 20 290 del 300;
#X obj 20 320 t b b b b;

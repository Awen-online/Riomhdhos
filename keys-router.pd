#N canvas 30 30 760 460 12;
#X obj 30 50 notein 1;
#X obj 30 80 stripnote;
#X obj 30 120 t f f;
#X obj 30 160 spigot;
#X obj 220 160 spigot;
#X obj 30 200 mtof;
#X obj 30 240 s basefreq;
#X obj 220 240 s jpitch;
#X obj 430 50 r keysinst;
#X obj 430 80 t f f;
#X obj 430 120 == 0;
#X obj 510 120 == 1;
#X obj 600 50 loadbang;
#X msg 600 85 0;
#X obj 600 120 s keysinst;
#X text 30 290 Routes the MiniLab keys to the selected instrument (main encoder). mode 0 = DRONE pitch -> basefreq \; mode 1 = JOUHIKKO pitch -> jpitch. Defaults to DRONE (0) on load.;
#X connect 0 0 1 0;
#X connect 0 1 1 1;
#X connect 1 0 2 0;

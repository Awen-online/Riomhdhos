[Unit]
Description=Folk Drone rig (Pure Data) autostart
After=sound.target multi-user.target
Wants=sound.target

[Service]
Type=simple
User=ian
SupplementaryGroups=audio
Environment=HOME=/home/ian
WorkingDirectory=/home/ian
ExecStartPre=/bin/sleep 8
ExecStart=/home/ian/Riomhdhos/start-rig.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

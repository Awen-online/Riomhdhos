#N canvas 30 30 760 480 12;
#X text 20 10 Loads the 4 staged samples into global tables and broadcasts each one's loop-freq (44100/len) and len for the sloop abstraction.;
#X obj 30 50 loadbang;
#X obj 520 40 table tbv;
#X msg 30 90 read -resize /home/ian/samples/boxviolin.wav tbv;
#X obj 30 130 soundfiler;
#X obj 30 170 t f f;
#X obj 30 200 s tbv-len;
#X obj 150 200 expr 44100.0/$f1;
#X obj 150 230 s tbv-freq;
#X obj 540 70 table tjou;
#X msg 30 280 read -resize /home/ian/samples/jouhikko.wav tjou;
#X obj 30 320 soundfiler;
#X obj 30 360 t f f;
#X obj 30 390 s tjou-len;
#X obj 150 390 expr 44100.0/$f1;
#X obj 150 420 s tjou-freq;
#X obj 560 100 table twindy;
#X msg 380 90 read -resize /home/ian/samples/windy.wav twindy;
#X obj 380 130 soundfiler;
#X obj 380 170 t f f;
#X obj 380 200 s twindy-len;
#X obj 510 200 expr 44100.0/$f1;
#X obj 510 230 s twindy-freq;
#X obj 580 130 table toflute;
#X msg 380 280 read -resize /home/ian/samples/oflute.wav toflute;
#X obj 380 320 soundfiler;
#X obj 380 360 t f f;
#X obj 380 390 s toflute-len;
#X obj 510 390 expr 44100.0/$f1;
#X obj 510 420 s toflute-freq;

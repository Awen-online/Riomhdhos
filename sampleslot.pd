#N canvas 30 30 540 460 12;
#X obj 20 20 notein 10;
#X obj 20 50 stripnote;
#X obj 20 80 sel $1;
#X obj 20 110 f;
#X obj 90 110 + 1;
#X obj 90 140 mod 2;
#X obj 20 170 sel 1 0;
#X obj 20 200 t b b;
#X obj 20 240 symbol $2;
#X obj 20 270 makefilename folk-samples/%s.wav;
#X msg 20 300 open $1;
#X msg 200 240 1;
#X msg 260 200 0;
#X obj 20 350 readsf~ 2;
#X obj 20 400 outlet~;
#X obj 90 400 outlet~;
#X text 150 80 pad note = $1  file = $2;
#X connect 0 0 1 0;
#X connect 0 1 1 1;
#X connect 1 0 2 0;
#X connect 2 0 3 0;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 5 0 3 1;
#X connect 5 0 6 0;
#X connect 6 0 7 0;
#X connect 7 1 8 0;
#X connect 8 0 9 0;
#X connect 9 0 10 0;
#X connect 10 0 13 0;
#X connect 7 0 11 0;
#X connect 11 0 13 0;
#X connect 6 1 12 0;
#X connect 12 0 13 0;
#X connect 13 0 14 0;
#X connect 13 1 15 0;
